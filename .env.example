# PhishGuard Configuration Example
# Copy this file to .env and fill in your actual API keys.
# DO NOT COMMIT .env if it contains real secrets.

# ===== Required Keys =====

# Anthropic API key (required for AI summary feature)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-your-real-key

# Nmap executable path (for network scanning; adjust for your OS)
# Windows local dev:
# NMAP_PATH=C:/Program Files (x86)/Nmap/nmap.exe
# Docker / Linux production (default in Dockerfile — usually omit this):
# NMAP_PATH=/usr/bin/nmap
NMAP_PATH=C:/Program Files (x86)/Nmap/nmap.exe

# ===== Third-Party Tool API Keys =====

# VirusTotal API Key
# Get one at: https://www.virustotal.com/gui/my-apikey
# VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# URLScan.io API Key
# Get one at: https://urlscan.io/user/profile/
# URLSCAN_API_KEY=your_urlscan_api_key_here

# AbuseIPDB API Key
# Get one at: https://www.abuseipdb.com/register
# ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# HaveIBeenPwned API Key (requires paid subscription)
# Get one at: https://haveibeenpwned.com/API/Key
# HIBP_API_KEY=your_hibp_api_key_here

# PhishTank API Key (optional — registration may be temporarily unavailable)
# Without a key, Sooty checks free public feeds (OpenPhish; PhishTank dump when available).
# Get one at: https://phishtank.org/register.php when registration is open.
# PHISHTANK_API_KEY=your_phishtank_api_key_here
# PHISHTANK_USE_LOCAL=true
PHISHTANK_APP_NAME=PhishGuard

# EmailRep API Key
# Get one at: https://emailrep.io/invite
# EMAILREP_API_KEY=your_emailrep_api_key_here

# ===== Phishing Catcher Configuration =====
# Score thresholds for category mapping (0-100 scale, applied after context adjustments)
# Legitimate brand domains (e.g. facebook.com) are adjusted down automatically.
PHISHING_THRESH_POTENTIAL=65
PHISHING_THRESH_LIKELY=80
PHISHING_THRESH_SUSPICIOUS=90
